{
  "permissions": {
    "defaultMode": "default"
  },
  "model": "haiku",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/scripts/3-level-flow.py",
            "timeout": 30,
            "statusMessage": "🔒 FULL POLICY ENFORCEMENT: Level -1 → Level 1 → Level 2 → Level 3 (All 15 steps)",
            "async": false
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Write|Edit|NotebookEdit|Bash|Read|Grep|Glob)$",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/scripts/pre-tool-enforcer.py",
            "timeout": 12,
            "statusMessage": "Level 3.6/3.7: Tool optimization + blocking enforcement...",
            "async": false
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Write|Edit|NotebookEdit|Bash|TaskCreate|TaskUpdate|Skill|Task)$",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/scripts/post-tool-tracker.py",
            "timeout": 30,
            "statusMessage": "Level 3.9-3.12: Progress + GitHub issue/close + flags...",
            "async": false
          }
        ]
      },
      {
        "matcher": "^(Read|Grep|Glob|WebFetch|WebSearch)$",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/scripts/post-tool-tracker.py",
            "timeout": 10,
            "statusMessage": "Level 3.9: Progress tracking...",
            "async": false
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/scripts/stop-notifier.py",
            "timeout": 60,
            "statusMessage": "Level 3.10: Session save + voice...",
            "async": false
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
