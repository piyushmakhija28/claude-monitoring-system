{
  "permissions": {
    "defaultMode": "default"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/techd/.claude/scripts/3-level-flow.py",
            "timeout": 120
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Write|Edit|NotebookEdit|Bash|Read|Grep|Glob)$",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/techd/.claude/scripts/pre-tool-enforcer.py",
            "timeout": 12
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Write|Edit|NotebookEdit|Bash|TaskCreate|TaskUpdate|Skill|Task)$",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/techd/.claude/scripts/post-tool-tracker.py",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "^(Read|Grep|Glob|WebFetch|WebSearch)$",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/techd/.claude/scripts/post-tool-tracker.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/techd/.claude/scripts/stop-notifier.py",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
